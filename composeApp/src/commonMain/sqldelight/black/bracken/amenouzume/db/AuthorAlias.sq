CREATE TABLE AuthorAlias (
    author_alias_id INTEGER NOT NULL PRIMARY KEY,
    author_id INTEGER NOT NULL REFERENCES Author(author_id) ON DELETE CASCADE,
    name TEXT NOT NULL UNIQUE
);

selectByAuthorId:
SELECT * FROM AuthorAlias WHERE author_id = :author_id;

selectByName:
SELECT * FROM AuthorAlias WHERE name = :name;

insert:
INSERT INTO AuthorAlias(author_id, name) VALUES (:author_id, :name);

deleteById:
DELETE FROM AuthorAlias WHERE author_alias_id = :author_alias_id;
